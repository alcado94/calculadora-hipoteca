---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Calculadora Hipotecaria España | Simula tu Hipoteca Gratis',
  description = 'Calcula tu hipoteca en España: cuotas, ITP/IVA/AJD, notaría y registro, esfuerzo financiero y comparativa alquiler vs compra. Gratis, sin registro.',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;

const ogImage = Astro.site
  ? new URL('/calculadora-hipoteca/og-image.png', Astro.site).href
  : '/calculadora-hipoteca/og-image.png';

const webApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Simulador de hipoteca',
  alternateName: ['Calculadora Hipotecaria', 'Calculadora Hipotecaria España', 'Calculadora de hipoteca'],
  description,
  url: canonicalURL.href,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  inLanguage: 'es-ES',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
  },
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/calculadora-hipoteca/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/calculadora-hipoteca/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="simulador de hipoteca, calculadora hipotecaria, calculadora de hipoteca, calculadora hipotecaria espana, hipoteca espana" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Calculadora Hipotecaria España" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(webApplicationSchema)}
    />

    <!-- Google Fonts: Geist Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        const storageKey = 'theme';
        const storedTheme = localStorage.getItem(storageKey);
        const hasStoredTheme = storedTheme === 'light' || storedTheme === 'dark';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolvedTheme = hasStoredTheme ? storedTheme : (prefersDark ? 'dark' : 'light');

        if (resolvedTheme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
